# ── Copy to .env and fill in. Load it into your shell before running:
#    set -a && source .env && set +a && ./mvnw spring-boot:run
# ─────────────────────────────────────────────────────────────────────

# PostgreSQL — for production this is Supabase Postgres. Render's network is
# IPv4-only, and Supabase's direct connection host is IPv6-only, so use the
# Session Pooler connection instead (Supabase dashboard → Connect → Session
# pooler tab shows the exact host/user for your project):
#   DB_URL=jdbc:postgresql://<pooler-host>:5432/postgres?sslmode=require
#   DB_USERNAME=postgres.<project-ref>          # note the .<project-ref> suffix
#   DB_PASSWORD=<your Supabase database password>
DB_URL=jdbc:postgresql://localhost:5432/advohq
DB_USERNAME=advohq
DB_PASSWORD=advohq

# Dedicated Postgres schema for this app, so it never collides with tables
# from any other project sharing the same database (e.g. Supabase's default
# "public" schema). Flyway creates it automatically on first boot.
DB_SCHEMA=advohq

# Server
SERVER_PORT=8080

# JWT — generate a 256-bit base64 secret:  openssl rand -base64 32
JWT_SECRET=Y2hhbmdlLW1lLXRoaXMtaXMtYS1kZXYtb25seS1zZWNyZXQtMzJieXRlcyE=
JWT_EXPIRATION_MS=43200000

# Allowed front-end origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:5500

# AWS S3 (client-provided documents)
AWS_REGION=ap-south-1
AWS_S3_BUCKET=advohq-documents
# Leave blank for real AWS; set to http://localhost:4566 for LocalStack
AWS_S3_ENDPOINT=
AWS_S3_PRESIGN_MINUTES=15

# AWS credentials — resolved by the default chain. For local dev you can set:
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
