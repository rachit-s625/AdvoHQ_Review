# Copy this file to `.env` and fill in your real key:  cp .env.example .env
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-opus-4-8
AI_MAX_PER_HOUR=20
AI_MAX_PER_MIN=6

# Signup email OTP — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
OTP_SECRET=generate-a-random-32-byte-base64-string

# Optional — without these, OTP codes are logged to the console instead of
# emailed (fine for local dev). Get an API key at https://app.brevo.com/settings/keys/api
BREVO_API_KEY=
BREVO_SENDER_EMAIL=onboarding@advohq.in
BREVO_SENDER_NAME=AdvoHQ
